"""
VOFA+ 数据分析用户脚本示例
"""

from vofa_analyzer import get_analyzer
import numpy as np

# ==================== 用户配置 ====================

# 第一通道是否为时间戳（微秒）
CHANNEL0_IS_TIMESTAMP = True

# CSV 文件路径（相对于脚本所在目录）
CSV_FILEPATH = "../../other_code/vofa+.csv"


# ==================== 主程序 ====================


def main():
    # 获取分析器实例
    analyzer = get_analyzer()

    # 设置配置
    analyzer.channel0_is_timestamp = CHANNEL0_IS_TIMESTAMP
    analyzer.csv_filepath = CSV_FILEPATH

    # 加载数据
    analyzer.load_data()
    analyzer.print_info()

    # 获取数据值（按通道索引）
    timestamp = analyzer.get_value(0)  # 第0通道（时间戳）
    value1 = analyzer.get_value(1)  # 第1通道数据

    # 用户自定义计算
    value1 = value1 + 1

    # 添加要绘制的通道（手动设置名称和颜色）
    analyzer.add_channel(timestamp, name="时间戳", color="#FF6B6B")
    analyzer.add_channel(value1, name="数据+1", color="#4ECDC4")

    # 绘图（带十字交叉线）
    analyzer.plot()


if __name__ == "__main__":
    main()