{
    // 启动调试的快捷键是F5
    "version": "0.2.0",
    "configurations": [
        {
            "name": "DAPlink",
            "type": "cortex-debug",
            "request": "launch",
            "preLaunchTask": "build",
            "cwd": "${workspaceRoot}",
            "executable": "${workspaceRoot}\\build\\${workspaceFolderBasename}.elf",
            "device": "STM32F407VET6",
            "svdFile": "STM32F407.svd",
            "servertype": "openocd",
            "configFiles": [
                "openocd_dap.cfg"
            ],
            "runToEntryPoint": "main",
            "rtos": "FreeRTOS",
            "liveWatch": {
                "enabled": true,
                "samplesPerSecond": 4
            }
        },
        {
            "name": "Jlink",
            "type": "cortex-debug",
            "request": "launch",
            "preLaunchTask": "build",
            "cwd": "${workspaceRoot}",
            "executable": "${workspaceRoot}\\build\\${workspaceFolderBasename}.elf",
            "device": "STM32F407VET6",
            "svdFile": "STM32F407.svd",
            "servertype": "jlink",
            "configFiles": [
                "openocd_dap.cfg"
            ],
            "runToEntryPoint": "main",
            "rtos": "FreeRTOS",
            "liveWatch": {
                "enabled": true,
                "samplesPerSecond": 4
            },
            "interface": "swd",
            "showDevDebugOutput": "none"
        },
        {
            "name": "DAP-attach",
            "type": "cortex-debug",
            "request": "attach",
            "cwd": "${workspaceRoot}",
            "executable": "${workspaceRoot}\\build\\${workspaceFolderBasename}.elf",
            "device": "STM32F407VET6",
            "svdFile": "STM32F407.svd",
            "servertype": "openocd",
            "configFiles": [
                "openocd_dap.cfg"
            ],
            "rtos": "FreeRTOS"
        },
        {
            "name": "Jlink-attach",
            "type": "cortex-debug",
            "request": "attach",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceRoot}\\build\\${workspaceFolderBasename}.elf",
            "device": "STM32F407IG",
            "svdFile": "STM32F407.svd",
            "servertype": "jlink",
            "rtos": "FreeRTOS",
            "interface": "swd",
            "showDevDebugOutput": "none"
        }
    ]
}