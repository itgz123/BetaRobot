            "servertype": "jlink",
            "runToEntryPoint": "main",
            "rtos": "FreeRTOS",
            "liveWatch": {
                "enabled": true,
                "samplesPerSecond": 4
            },
            "interface": "swd",
            "showDevDebugOutput": "none"
