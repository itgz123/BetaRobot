    "version": "0.2.0",
    "configurations": [
        // ==================== TELESKY_VET6 (STM32F407VET6) ====================
        {
            "name": "TELESKY_VET6 - DAPlink",
            "type": "cortex-debug",
            "request": "launch",
            "preLaunchTask": "TELESKY_VET6 - build",
            "cwd": "${workspaceRoot}",
            "executable": "${workspaceRoot}\\build\\BetaRobot.elf",
            "device": "STM32F407VET6",
            "svdFile": "${workspaceRoot}/hal/STM32F407VET6/STM32F407.svd",
            "servertype": "openocd",
            "configFiles": [
                "openocd_dap.cfg"
            ],
            "runToEntryPoint": "main",
            "rtos": "FreeRTOS",
            "liveWatch": {
                "enabled": true,
                "samplesPerSecond": 4
            }
        },
        {
            "name": "TELESKY_VET6 - Jlink",
