{
    "version": "2.0.0",
    "inputs": [
        {
            "id": "selectBoard",
            "type": "pickString",
            "description": "选择开发板",
            "options": [
                "STM32F407VET6",
                "DM_MC02",
                "DJI_A",
                "DJI_C"
            ],
            "default": "STM32F407VET6"
        }
    ],
    "tasks": [
        // ==================== 构建任务 ====================
        {
            "label": "build",
            "type": "shell",
            "command": "${config:betaRobot.makeCommand} -j${config:betaRobot.buildJobs}",
            "detail": "编译（根据 user_cfg.h 的 APP_NAME 和 app_cfg.h 的 DEVELOPMENT_BOARD）",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        // ==================== 下载任务 ====================
        {
            "label": "download dap",
            "type": "shell",
            "command": "${config:betaRobot.makeCommand} download_dap",
            "detail": "使用DAPlink下载",
            "group": {},
            "problemMatcher": []
        },
        {
            "label": "download jlink",
            "type": "shell",
            "command": "${config:betaRobot.makeCommand} download_jlink",
            "detail": "使用Jlink下载",
            "group": {},
            "problemMatcher": []
        },
        // ==================== 公共任务 ====================
        {
            "label": "clean",
            "type": "shell",
            "command": "${config:betaRobot.makeCommand} clean",
            "detail": "清理构建目录",
            "group": {},
            "problemMatcher": []
        },
        {
            "label": "DAP-link RTT",
            "type": "shell",
            "command": "Start-Process openocd -ArgumentList '-f','${workspaceFolder}/hal/${input:selectBoard}/openocd_rtt.cfg'; Start-Sleep -Seconds 2; putty -telnet 127.0.0.1 -P 8888",
            "detail": "启动DAP-Link RTT服务并用PuTTY连接",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        }
    ]
}