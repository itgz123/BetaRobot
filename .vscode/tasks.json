{
    "version": "2.0.0",
    "inputs": [
        {
            "id": "selectBoard",
            "type": "pickString",
            "description": "选择开发板",
            "options": [
                "DM_MC02",
                "DJI_A",
                "DJI_C"
            ],
            "default": "DM_MC02"
        }
    ],
    "tasks": [
        {
            "label": "build",
            "type": "shell",
            "command": "cmake --preset default ; cmake --build build -j24",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "detail": "配置并编译项目",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "download dap",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build",
                "--target",
                "download_dap"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "detail": "使用 DAPlink 下载",
            "problemMatcher": []
        },
        {
            "label": "download jlink",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build",
                "--target",
                "download_jlink"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "detail": "使用 J-Link 下载",
            "problemMatcher": []
        },
        {
            "label": "clean",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-E",
                "rm",
                "-rf",
                "build"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "detail": "删除构建目录",
            "problemMatcher": []
        },
        {
            "label": "DAP-link RTT",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build",
                "--target",
                "rtt_connect"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "detail": "启动 RTT 调试连接",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        }
    ]
}
