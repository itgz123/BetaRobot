{
    "version": "2.0.0",
    "inputs": [
        {
            "id": "selectBoard",
            "type": "pickString",
            "description": "选择开发板",
            "options": [
                "STM32F407VET6",
                "DM_MC02",
                "DJI_A",
                "DJI_C"
            ],
            "default": "STM32F407VET6"
        },
        {
            "id": "selectBuildType",
            "type": "pickString",
            "description": "选择构建类型",
            "options": [
                "Debug",
                "Release"
            ],
            "default": "Debug"
        }
    ],
    "tasks": [
        {
            "label": "build",
            "type": "shell",
            "command": "cmake --preset ${input:selectBuildType} 2>$null; cmake --build build -j${config:betaRobot.buildJobs}",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "detail": "使用 CMake + Ninja 编译（自动检测配置变化）",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "download dap",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build",
                "--target",
                "download_dap"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "detail": "使用 DAPlink 下载",
            "problemMatcher": []
        },
        {
            "label": "download jlink",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build",
                "--target",
                "download_jlink"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "detail": "使用 J-Link 下载",
            "problemMatcher": []
        },
        {
            "label": "clean",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-E",
                "rm",
                "-rf",
                "build"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "detail": "删除构建目录",
            "problemMatcher": []
        },
        {
            "label": "DAP-link RTT",
            "type": "shell",
            "command": "Start-Process openocd -ArgumentList '-f','${workspaceFolder}/hal/${input:selectBoard}/openocd_rtt.cfg'; Start-Sleep -Seconds 2; putty -telnet 127.0.0.1 -P 8888",
            "detail": "启动 DAP-Link RTT 服务并用 PuTTY 连接",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        }
    ]
}